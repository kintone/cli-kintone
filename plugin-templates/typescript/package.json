{
  "name": "kintone-plugin-template-typescript",
  "version": "0.1.0",
  "scripts": {
    "prestart": "npm run build",
    "start": "node scripts/npm-start.js",
    "upload": "cli-kintone plugin upload --input dist/plugin.zip --watch",
    "develop": "npm run build -- --watch",
    "keygen": "cli-kintone plugin keygen --output private.ppk",
    "build": "cross-env NODE_ENV=development webpack",
    "build:prod": "cross-env NODE_ENV=production webpack",
    "dts-gen": "kintone-dts-gen",
    "lint": "eslint src"
  },
  "dependencies": {
    "@kintone/rest-api-client": "6.2.0",
    "core-js": "3.40.0"
  },
  "devDependencies": {
    "@babel/core": "8.0.1",
    "@babel/preset-env": "8.0.2",
    "@babel/preset-react": "8.0.1",
    "@babel/preset-typescript": "8.0.1",
    "@cybozu/eslint-config": "25.0.1",
    "@kintone/cli": "1.20.0",
    "@kintone/dts-gen": "9.0.7",
    "@kintone/webpack-plugin-kintone-plugin": "9.0.4",
    "ajv": "8.20.0",
    "babel-loader": "9.2.1",
    "cross-env": "7.0.3",
    "eslint": "9.39.4",
    "npm-run-all": "4.1.5",
    "prettier": "3.8.4",
    "typescript": "5.9.3",
    "webpack": "5.107.2",
    "webpack-cli": "6.0.1"
  }
}
