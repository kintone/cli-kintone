{
  "manifest_version": 1,
  "version": 1,
  "type": "APP",
  "name": {
    "en": "sandbox sample"
  },
  "icon": "image/icon.png",
  "sandbox": true,
  "allowed_hosts": [
    "https://example.com",
    "wss://example.com",
    "https://example.com/api/*",
    "*"
  ],
  "permissions": {
    "js_api": ["app:read", "network:connect"],
    "rest_api": ["app_record:read", "file:write"]
  }
}
